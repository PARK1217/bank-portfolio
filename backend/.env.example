# 로컬(비-Docker) 실행용. Docker 실행 시에는 docker-compose.yml 의 environment 가 주입됩니다.
DATABASE_URL=postgresql://bank:bank1234@localhost:5434/bank
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
CORS_ORIGINS=http://localhost:3001

# 로깅 (가이드 §3.1). 미설정 시 INFO / ./logs.
LOG_LEVEL=INFO
LOG_DIR=logs
